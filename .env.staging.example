# Copy this file to .env.staging when preparing a real staging validation run.
# Runtime deploy variables should still use the canonical names from .env.example.

# Staging database used by billing validation
STAGING_DB_URL=postgresql://postgres:password@db.example.com:5432/curria_staging

# Public staging application URL
STAGING_API_URL=https://staging-curria.example.com

# Asaas sandbox credentials used by scripts/verify-staging.sh
STAGING_ASAAS_WEBHOOK_TOKEN=sandbox_webhook_token_replace_me
STAGING_ASAAS_ACCESS_TOKEN=sandbox_access_token_replace_me

# Optional fallback when psql is unavailable on the operator workstation.
# Reuse the canonical runtime values from .env / hosting config.
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=supabase_service_role_replace_me

# Optional staging-only diagnostics
STAGING_LOG_LEVEL=debug
STAGING_ENABLE_DETAILED_LOGGING=true
