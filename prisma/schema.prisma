generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  phase        String    @default("intake")
  cvState      Json      @map("cv_state")
  atsScore     Json?     @map("ats_score")
  creditsUsed  Int       @default(0) @map("credits_used")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  messages     Message[]

  @@index([userId])
  @@map("sessions")
}

model Message {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model UserQuota {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  plan                String    @default("free")  // "free" | "monthly" | "pro"
  creditsRemaining    Int       @default(0) @map("credits_remaining")
  asaasCustomerId     String?   @map("asaas_customer_id")
  asaasSubscriptionId String?   @map("asaas_subscription_id")
  renewsAt            DateTime? @map("renews_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([asaasCustomerId])
  @@index([asaasSubscriptionId])
  @@map("user_quotas")
}

model ProcessedEvent {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  eventType String   @map("event_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([eventId, eventType])
  @@map("processed_events")
}
