# Copy this file to .env for local development.
# Only placeholder values belong here. Never commit real secrets.

# Database and Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/curria
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/curria

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=supabase_service_role_replace_me

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Optional Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=

# OpenAI
OPENAI_API_KEY=sk-replace_me

# Optional OpenAI baseline combo
OPENAI_MODEL_COMBO=

# Optional OpenAI agent override (preferred over OPENAI_MODEL)
OPENAI_AGENT_MODEL=

# Optional compatibility alias for the agent override
OPENAI_MODEL=

# Optional OpenAI override for dialog and confirm turns only
OPENAI_DIALOG_MODEL=

# Optional OpenAI proxy override
OPENAI_BASE_URL=

# Asaas
ASAAS_ACCESS_TOKEN=asaas_access_token_replace_me
ASAAS_WEBHOOK_TOKEN=asaas_webhook_token_replace_me

# Optional Asaas sandbox switch
ASAAS_SANDBOX=true

# Upstash
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_token_replace_me

# Optional integrations
LINKDAPI_API_KEY=

# Optional local-only E2E browser auth seam
E2E_AUTH_ENABLED=
E2E_AUTH_BYPASS_SECRET=
E2E_AUTH_ALLOW_LOCAL_DEV=

# Export worker/runtime separation
APP_RUNTIME_ROLE=web
EXPORT_GENERATION_MAX_CONCURRENCY=3
EXPORT_GENERATION_MAX_PER_USER=1
EXPORT_GENERATION_TIMEOUT_MS=90000
EXPORT_GENERATION_RETRY_DELAYS_MS=10000,30000,120000
EXPORT_WORKER_POLL_INTERVAL_MS=2000
EXPORT_WORKER_CLAIM_BATCH_SIZE=12

# Internal ops dashboard allowlist
OPERATIONS_DASHBOARD_EMAILS=
